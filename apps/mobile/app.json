{
  "expo": {
    "name": "mobile",
    "slug": "mobile",
    "owner": "khongvantam88",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.htuan04.mobile",
      "bitcode": false,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.htuan04.mobile",
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "MODIFY_AUDIO_SETTINGS",
        "BLUETOOTH",
        "ACCESS_NETWORK_STATE",
        "INTERNET",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-media-library",
      "expo-location",
      [
        "@config-plugins/react-native-webrtc",
        {
          "cameraPermission": "Zalo-clone cần quyền truy cập Camera để gọi Video.",
          "microphonePermission": "Zalo-clone cần quyền truy cập Micro để đàm thoại."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Ứng dụng cần truy cập thư viện ảnh của bạn.",
          "cameraPermission": "Ứng dụng cần truy cập Máy ảnh."
        }
      ],
      "expo-splash-screen",
      "expo-file-system",
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "eas": {
        "projectId": "c619151f-f709-4849-98b9-d0c2ce7b43bd"
      }
    }
  }
}